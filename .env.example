# Provider auto-detection: set ONE of these API keys.
# Priority: NVIDIA → Groq → Anthropic
# Or force a provider: LLM_PROVIDER=nvidia|anthropic|groq

# NVIDIA (free tier at build.nvidia.com)
# NVIDIA_API_KEY=nvapi-xxxxx

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# Groq (free tier)
# GROQ_API_KEY=gsk_xxxxx

# Optional: override the default model for your provider
# SUPERVISOR_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1
